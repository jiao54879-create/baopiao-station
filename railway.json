{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "plan": "nodejs"
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "override": {
      "command": "npx prisma migrate deploy && npx prisma db seed && node dist/index.js",
      "rootDirectory": "backend"
    }
  }
}
