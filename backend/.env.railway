# Railway/Render 部署环境变量
# 复制到 Railway 控制台配置

# ==================== 数据库 ====================
# 开发环境：SQLite（本地）
# 生产环境：使用 Railway 提供的 PostgreSQL
DATABASE_URL="postgresql://user:password@host:5432/baopiao"

# ==================== 服务配置 ====================
PORT=3001
NODE_ENV=production
FRONTEND_URL=https://your-frontend.vercel.app

# ==================== Claude AI（必填）====================
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ==================== JWT ====================
JWT_SECRET=generate-a-secure-random-string-here
JWT_EXPIRES_IN=7d

# ==================== 限流 ====================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
