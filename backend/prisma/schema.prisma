generator client {
  provider = "prisma-client-js"
}

datasource db {
  // 开发环境使用 SQLite，生产环境改为 postgresql
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户与权限 ====================

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  role          String    @default("MEMBER") // ADMIN, MEMBER, VIEWER
  teamId        Int?
  team          Team?     @relation(fields: [teamId], references: [id])
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  preferences   String    @default("{}") // JSON string
  isActive      Boolean   @default(true)

  // 关系
  savedTitles   SavedTitle[]
  savedCases    SavedCase[]
  savedIntelligences SavedIntelligence[]
  teamInvites   TeamInvite[] @relation("InviteUser")
  activityLogs  ActivityLog[]

  @@map("users")
}

model Team {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  isActive    Boolean   @default(true)

  // 关系
  members     User[]
  invites     TeamInvite[]
  sharedTitles SavedTitle[] @relation("TeamSaved")

  @@map("teams")
}

model TeamInvite {
  id        Int       @id @default(autoincrement())
  teamId    Int
  team      Team      @relation(fields: [teamId], references: [id])
  email     String
  token     String    @unique
  role      String    @default("MEMBER")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  createdBy Int
  creator   User      @relation("InviteUser", fields: [createdBy], references: [id])

  @@map("team_invites")
}

// ==================== 情报数据 ====================

model Intelligence {
  id           Int       @id @default(autoincrement())
  title        String
  summary      String?
  content      String?
  source       String    // 来源平台
  sourceUrl    String?
  category     String    // INSURANCE, FINANCE, EDUCATION, TECH, SOCIAL, HEALTH
  tags         String    @default("[]") // JSON array string
  hotScore     Int       @default(0)
  publishTime  DateTime?
  createdAt    DateTime  @default(now())

  // 关系
  savedBy      SavedIntelligence[]

  @@index([category])
  @@index([publishTime])
  @@index([hotScore])
  @@map("intelligence")
}

// ==================== 爆款案例 ====================

model ViralCase {
  id              Int       @id @default(autoincrement())
  platform        String    // XHS, WX, DOUYIN, VIDEO, WEIBO, ZHIHU
  title           String
  content         String?
  author          String?
  authorUrl       String?
  likesCount      Int       @default(0)
  favoritesCount  Int       @default(0)
  commentsCount   Int       @default(0)
  sharesCount     Int       @default(0)
  url             String
  coverImage      String?
  tags            String    @default("[]") // JSON array string
  insuranceType   String?   // 关联险种
  viralScore      Float?    // AI 计算的爆款分
  analysis        String?   // AI 爆款分析
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  // 关系
  savedBy         SavedCase[]

  @@index([platform])
  @@index([viralScore])
  @@index([publishedAt])
  @@map("viral_cases")
}

// ==================== 标题收藏 ====================

model SavedTitle {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  keywords        String    @default("[]") // JSON array string
  generatedTitles String    // JSON array string
  finalTitle      String?
  status          String    @default("DRAFT") // DRAFT, USED, ARCHIVED
  notes           String?
  teamId          Int?
  team            Team?     @relation("TeamSaved", fields: [teamId], references: [id])
  createdAt       DateTime  @default(now())
  usedAt          DateTime?

  @@map("saved_titles")
}

// ==================== 收藏记录 ====================

model SavedCase {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  caseId     Int
  case       ViralCase @relation(fields: [caseId], references: [id])
  notes      String?
  createdAt  DateTime  @default(now())

  @@unique([userId, caseId])
  @@map("saved_cases")
}

model SavedIntelligence {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  intelligenceId Int
  intelligence  Intelligence @relation(fields: [intelligenceId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())

  @@unique([userId, intelligenceId])
  @@map("saved_intelligences")
}

// ==================== 采集任务 ====================

model ScrapeTask {
  id          Int       @id @default(autoincrement())
  name        String
  source      String
  sourceUrl   String
  category    String    // INSURANCE, FINANCE, EDUCATION, TECH, SOCIAL, HEALTH
  schedule    String    // cron 表达式
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  status      String    @default("ACTIVE") // ACTIVE, PAUSED, ERROR
  config      String?   // JSON string
  createdAt   DateTime  @default(now())

  @@map("scrape_tasks")
}

// ==================== 操作日志 ====================

model ActivityLog {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  action     String    // 操作类型
  resource   String?   // 资源类型
  resourceId Int?
  details    String?   // JSON string
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
