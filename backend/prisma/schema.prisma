generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Railway 生产环境使用 PostgreSQL，本地开发使用 SQLite
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与权限 ====================

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  email         String    @unique
  passwordHash  String
  role          String    @default("MEMBER") // ADMIN, MEMBER, VIEWER
  teamId        Int?
  team          Team?     @relation(fields: [teamId], references: [id])
  createdAt     DateTime  @default(now())
  lastLoginAt   DateTime?
  preferences   String    @default("{}") // JSON string
  isActive      Boolean   @default(true)

  // 关系
  savedTitles   SavedTitle[]
  savedCases    SavedCase[]
  savedIntelligences SavedIntelligence[]
  teamInvites   TeamInvite[] @relation("InviteUser")
  activityLogs  ActivityLog[]

  @@map("users")
}

model Team {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  isActive    Boolean   @default(true)

  // 关系
  members     User[]
  invites     TeamInvite[]
  sharedTitles SavedTitle[] @relation("TeamSaved")

  @@map("teams")
}

model TeamInvite {
  id        Int       @id @default(autoincrement())
  teamId    Int
  team      Team      @relation(fields: [teamId], references: [id])
  email     String
  token     String    @unique
  role      String    @default("MEMBER")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  createdBy Int
  creator   User      @relation("InviteUser", fields: [createdBy], references: [id])

  @@map("team_invites")
}

// ==================== 情报数据 ====================

model Intelligence {
  id           Int       @id @default(autoincrement())
  title        String
  summary      String?
  content      String?
  source       String    // 来源平台
  sourceUrl    String?
  category     String    // INSURANCE, FINANCE, EDUCATION, TECH, SOCIAL, HEALTH
  tags         String    @default("[]") // JSON array string
  hotScore     Int       @default(0)
  publishTime  DateTime?
  createdAt    DateTime  @default(now())

  // 关联产品ID
  linkedProductId  Int?
  linkedProduct    InsuranceProduct? @relation(fields: [linkedProductId], references: [id])
  // 是否为产品相关情报
  isProductNews    Boolean   @default(false)
  // 产品新闻类型
  productNewsType  String?   // NEW_PRODUCT, PRODUCT_UPDATE, PRODUCT_OFFLINE, RATE_ADJUSTMENT

  // 关系
  savedBy      SavedIntelligence[]

  @@index([category])
  @@index([publishTime])
  @@index([hotScore])
  @@index([linkedProductId])
  @@map("intelligence")
}

// ==================== 爆款案例 ====================

model ViralCase {
  id              Int       @id @default(autoincrement())
  platform        String    // XHS, WX, DOUYIN, VIDEO, WEIBO, ZHIHU
  title           String
  content         String?
  author          String?
  authorUrl       String?
  likesCount      Int       @default(0)
  favoritesCount  Int       @default(0)
  commentsCount   Int       @default(0)
  sharesCount     Int       @default(0)
  url             String
  coverImage      String?
  tags            String    @default("[]") // JSON array string
  insuranceType   String?   // 关联险种
  viralScore      Float?    // AI 计算的爆款分
  analysis        String?   // AI 爆款分析
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())

  // 关联产品
  linkedProductId Int?
  linkedProduct   InsuranceProduct? @relation(fields: [linkedProductId], references: [id])

  // 关系
  savedBy         SavedCase[]

  @@index([platform])
  @@index([viralScore])
  @@index([publishedAt])
  @@index([linkedProductId])
  @@map("viral_cases")
}

// ==================== 保险产品分析 ====================

model InsuranceProduct {
  id              Int       @id @default(autoincrement())
  
  // 基础信息
  name            String    // 产品名称（如"超级玛丽13号"）
  company         String    // 保险公司（如"君龙人寿"）
  insuranceType   String    // 险种（HEALTH/TERM/LIFE/ACCIDENT/ENDOWMENT/CRITICAL_ILLNESS/CHILDREN）
  
  // 产品状态
  status          String    @default("NEW")  // NEW(新上架)/HOT(热门)/NORMAL(在售)/OFFLINE(已下架)
  
  // 价格计算（标准化：成人30岁/30万/30年交/保终身；儿童0岁/50万/30年交/保终身）
  priceAdult30    Float?    // 成人年缴保费
  priceChild0     Float?    // 儿童年缴保费
  
  // 时间管理
  launchDate      DateTime? // 上架时间
  offlineDate     DateTime? // 下架时间
  estimatedOffline DateTime? // 预估下架时间
  
  // ====== 深度分析字段 ======
  
  // 产品亮点（JSON数组）
  highlightsSevere    String @default("[]") // 重症保障亮点
  highlightsMild       String @default("[]") // 轻症保障亮点
  highlightsWaiver     String @default("[]") // 豁免功能亮点
  highlightsSpecial    String @default("[]") // 特色保障亮点（癌症多次赔等）
  highlightsValue      String @default("[]") // 增值服务亮点
  
  // 核心优势（JSON数组）
  advantagesPrice      String @default("[]") // 价格优势
  advantagesCoverage   String @default("[]") // 保障优势
  advantagesUW         String @default("[]") // 核保优势
  advantagesService    String @default("[]") // 服务优势
  
  // 竞品对比
  competitors          String @default("[]") // JSON数组，竞品名称列表
  competitorComparison String?             // 竞品对比详情（JSON格式）
  
  // 产品缺点/注意事项
  drawbacks            String @default("[]") // JSON数组
  
  // ====== 元数据 ======
  
  // 来源追踪
  source          String?   // 发现来源
  sourceUrl       String?   // 来源链接
  notes           String?   // 备注信息
  lastUpdated     DateTime @default(now())  // 最后更新时间
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // 关联关系
  intelligences   Intelligence[]
  viralCases      ViralCase[]
  
  @@index([status])
  @@index([insuranceType])
  @@index([company])
  @@index([launchDate])
  @@map("insurance_products")
}

// ==================== 标题收藏 ====================

model SavedTitle {
  id              Int       @id @default(autoincrement())
  userId          Int
  user            User      @relation(fields: [userId], references: [id])
  keywords        String    @default("[]") // JSON array string
  generatedTitles String    // JSON array string
  finalTitle      String?
  status          String    @default("DRAFT") // DRAFT, USED, ARCHIVED
  notes           String?
  teamId          Int?
  team            Team?     @relation("TeamSaved", fields: [teamId], references: [id])
  createdAt       DateTime  @default(now())
  usedAt          DateTime?

  @@map("saved_titles")
}

// ==================== 收藏记录 ====================

model SavedCase {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  caseId     Int
  case       ViralCase @relation(fields: [caseId], references: [id])
  notes      String?
  createdAt  DateTime  @default(now())

  @@unique([userId, caseId])
  @@map("saved_cases")
}

model SavedIntelligence {
  id            Int         @id @default(autoincrement())
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  intelligenceId Int
  intelligence  Intelligence @relation(fields: [intelligenceId], references: [id])
  notes         String?
  createdAt     DateTime    @default(now())

  @@unique([userId, intelligenceId])
  @@map("saved_intelligences")
}

// ==================== 采集任务 ====================

model ScrapeTask {
  id          Int       @id @default(autoincrement())
  name        String
  source      String
  sourceUrl   String
  category    String    // INSURANCE, FINANCE, EDUCATION, TECH, SOCIAL, HEALTH
  schedule    String    // cron 表达式
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  status      String    @default("ACTIVE") // ACTIVE, PAUSED, ERROR
  config      String?   // JSON string
  createdAt   DateTime  @default(now())

  @@map("scrape_tasks")
}

// ==================== 操作日志 ====================

model ActivityLog {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id])
  action     String    // 操作类型
  resource   String?   // 资源类型
  resourceId Int?
  details    String?   // JSON string
  ip         String?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}
